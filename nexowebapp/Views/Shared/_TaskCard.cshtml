@model nexowebapp.Models.ViewModels.TaskCardViewModel

<div class="card task-card-wrap" onclick="location.href='@Url.Action("Details", "Task", new { id = Model.Id })'">
    <div class="between" style="margin-bottom: 12px">
        <div class="row" style="gap: 8px">
            <span class="badge b-gray">@Model.Category</span>
            @if (Model.IsUrgent)
            {
                <span class="badge b-red">⚡ Urgent</span>
            }
        </div>
        <button style="width: 34px; height: 34px; fontSize: 15px; border: none; background: transparent; cursor: pointer; opacity: 0.35; transition: opacity 0.2s"
                onclick="event.stopPropagation();">
            🔖
        </button>
    </div>
    <h3 style="font-size: 15px; font-weight: 600; color: #1a1a2e; margin-bottom: 8px; line-height: 1.4">@Model.Title</h3>
    <p style="font-size: 13px; color: #888; line-height: 1.55; margin-bottom: 14px">@(Model.Description?.Length > 85 ? Model.Description.Substring(0, 85) + "…" : Model.Description)</p>
    <div class="between">
        <div style="display: flex; gap: 14px; font-size: 12px; color: #aaa">
            <span>📍 @Model.Distance km</span>
            <span>⏰ @Model.Deadline</span>
        </div>
        <div style="font-family: 'Playfair Display', serif; font-size: 20px; color: #00A870; font-weight: 600">PKR @Model.Budget.ToString("N0")</div>
    </div>
    <div class="div" style="margin: 14px 0" />
    <div class="between">
        <div class="row">
            <div class="av" style="width: 30px; height: 30px; font-size: 11px">@Model.PosterAvatar</div>
            <span style="font-size: 13px; color: #666; font-weight: 500">@Model.PosterName</span>
            <span class="stars" style="font-size: 12px">★ @Model.PosterRating</span>
        </div>
        <a class="btn btn-green btn-sm" asp-controller="Task" asp-action="Details" asp-route-id="@Model.Id">View →</a>
    </div>
</div>
