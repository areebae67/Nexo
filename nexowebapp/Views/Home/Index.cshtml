@using nexowebapp.Models.ViewModels
@{
    ViewData["Title"] = "Hyperlocal Task Marketplace";
    
    var featuredTasks = new List<TaskCardViewModel>
    {
        new TaskCardViewModel { Id = 1, Title = "Deep clean 3-bedroom apartment", Description = "Full deep clean including kitchen, bathrooms, and all rooms.", Budget = 4500, Distance = "1.2", Deadline = "May 10", Category = "Cleaning", IsUrgent = false, PosterName = "Ayesha K.", PosterAvatar = "AK", PosterRating = 4.8 },
        new TaskCardViewModel { Id = 2, Title = "Fix leaking kitchen faucet", Description = "Kitchen faucet has been dripping for a week. Need a licensed plumber ASAP.", Budget = 2000, Distance = "0.8", Deadline = "May 6", Category = "Repair", IsUrgent = true, PosterName = "Omar B.", PosterAvatar = "OB", PosterRating = 4.6 },
        new TaskCardViewModel { Id = 3, Title = "Move furniture to new apartment", Description = "Need 3 people to help move heavy furniture across town.", Budget = 6000, Distance = "3.5", Deadline = "May 12", Category = "Moving", IsUrgent = false, PosterName = "Sara N.", PosterAvatar = "SN", PosterRating = 4.9 },
        new TaskCardViewModel { Id = 4, Title = "MCAT prep tutoring — 3 sessions", Description = "Looking for an experienced MCAT tutor for Biology and Chemistry.", Budget = 9000, Distance = "2.1", Deadline = "May 15", Category = "Tutoring", IsUrgent = false, PosterName = "Ali H.", PosterAvatar = "AH", PosterRating = 5.0 }
    };

    var categories = new List<CategoryViewModel>
    {
        new CategoryViewModel { Name = "Cleaning", Emoji = "🧹", Count = 34, Color = "#E8FAF3" },
        new CategoryViewModel { Name = "Repair", Emoji = "🔧", Count = 28, Color = "#FEF3E2" },
        new CategoryViewModel { Name = "Delivery", Emoji = "📦", Count = 19, Color = "#E8F0FE" },
        new CategoryViewModel { Name = "Tutoring", Emoji = "📚", Count = 22, Color = "#FCE8F0" },
        new CategoryViewModel { Name = "Moving", Emoji = "🚚", Count = 11, Color = "#E8FAF3" },
        new CategoryViewModel { Name = "Gardening", Emoji = "🌿", Count = 8, Color = "#F0FDF4" },
        new CategoryViewModel { Name = "Tech Help", Emoji = "💻", Count = 15, Color = "#EDE9FE" },
        new CategoryViewModel { Name = "Cooking", Emoji = "🍳", Count = 6, Color = "#FFF7ED" }
    };
}

<div class="page">
    @* Hero Section *@
    <div style="background: #fff; padding: 88px 48px 72px; text-align: center; border-bottom: 1px solid #f0f0f0">
        <div style="display: inline-flex; align-items: center; gap: 8px; background: #E8FAF3; border-radius: 32px; padding: 6px 16px; margin-bottom: 24px">
            <span style="width: 7px; height: 7px; background: #00A870; border-radius: 50%; display: inline-block"></span>
            <span style="font-size: 12px; color: #00924a; font-weight: 500; letter-spacing: 0.5px">Live in Karachi · Lahore · Islamabad</span>
        </div>
        <h1 style="font-family: 'Playfair Display', serif; font-size: 56px; color: #1a1a2e; line-height: 1.1; margin-bottom: 18px; letter-spacing: -1px">
            Get anything done,<br /><span style="color: #00A870">right nearby.</span>
        </h1>
        <p style="font-size: 17px; color: #888; margin-bottom: 40px; max-width: 480px; margin: 0 auto 40px; line-height: 1.6">
            Post a task, match with verified locals, and track everything live.
        </p>
        <div style="display: flex; background: #F7F8FA; border: 1.5px solid #e0e0e0; border-radius: 40px; overflow: hidden; max-width: 580px; margin: 0 auto; padding: 6px 6px 6px 24px; align-items: center; gap: 12px; box-shadow: 0 4px 24px rgba(0,0,0,0.06)">
            <span style="font-size: 18px">🔍</span>
            <input style="flex: 1; border: none; background: transparent; font-size: 15px; outline: none; font-family: 'DM Sans', sans-serif; color: #1a1a2e"
                   placeholder="What do you need done today?" />
            <button class="btn btn-green">Find Help</button>
        </div>
        <div style="margin-top: 24px; display: flex; gap: 28px; justify-content: center; font-size: 13px; color: #aaa">
            <span>✓ Verified providers</span>
            <span>✓ Real-time tracking</span>
            <span>✓ Secure payments</span>
            <span>✓ Instant match</span>
        </div>
    </div>

    @* Marquee/Live Tasks Section *@
    <div style="background: #FAFBFC; padding: 48px 0 40px; border-bottom: 1px solid #f0f0f0">
        <div style="text-align: center; margin-bottom: 28px">
            <span style="font-size: 12px; color: #aaa; font-weight: 500; letter-spacing: 1px; text-transform: uppercase">⚡ Live Tasks Near You — hover to pause</span>
        </div>
        <div class="marquee-wrap">
            <div class="marquee-track">
                @foreach (var task in featuredTasks.Concat(featuredTasks))
                {
                    <div style="width: 260px; flex-shrink: 0">
                        <div class="card" style="transform: none">
                            <div class="between" style="margin-bottom: 8px">
                                <span class="badge b-gray" style="font-size: 11px">@task.Category</span>
                                @if (task.IsUrgent)
                                {
                                    <span class="badge b-red" style="font-size: 11px">⚡</span>
                                }
                            </div>
                            <p style="font-weight: 600; font-size: 13px; color: #1a1a2e; margin-bottom: 8px; line-height: 1.4">@(task.Title?.Length > 42 ? task.Title.Substring(0, 42) + "…" : task.Title)</p>
                            <div class="between">
                                <span style="font-size: 12px; color: #aaa">📍 @task.Distance km</span>
                                <span style="font-family: 'Playfair Display', serif; font-size: 17px; color: #00A870; font-weight: 600">PKR @task.Budget.ToString("N0")</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    @* Categories Section *@
    <div class="section" style="background: #fff; border-bottom: 1px solid #f0f0f0">
        <div style="text-align: center; margin-bottom: 36px">
            <h2 class="s-title">Browse by Category</h2>
            <p class="s-sub">Find the right help for every task</p>
        </div>
        <div class="grid4" style="max-width: 900px; margin: 0 auto">
            @foreach (var cat in categories)
            {
                <partial name="_CatCard" model="cat" />
            }
        </div>
    </div>

    @* How it works Section *@
    <div class="section" style="background: #F7F8FA; border-bottom: 1px solid #f0f0f0">
        <div style="text-align: center; margin-bottom: 40px">
            <h2 class="s-title">How Nexo works</h2>
            <p class="s-sub">Get help in 3 simple steps</p>
        </div>
        <div class="grid3" style="max-width: 800px; margin: 0 auto">
            <div class="card-flat" style="text-align: center; padding: 32px">
                <div style="font-size: 32px; margin-bottom: 14px">📝</div>
                <div style="font-family: 'Playfair Display', serif; font-size: 13px; color: #00A870; margin-bottom: 8px">01</div>
                <h3 style="font-weight: 600; font-size: 16px; margin-bottom: 10px; color: #1a1a2e">Post your task</h3>
                <p style="font-size: 13px; color: #888; line-height: 1.6">Describe what you need, set your budget, and choose your location radius.</p>
            </div>
            <div class="card-flat" style="text-align: center; padding: 32px">
                <div style="font-size: 32px; margin-bottom: 14px">⚡</div>
                <div style="font-family: 'Playfair Display', serif; font-size: 13px; color: #00A870; margin-bottom: 8px">02</div>
                <h3 style="font-weight: 600; font-size: 16px; margin-bottom: 10px; color: #1a1a2e">Get matched instantly</h3>
                <p style="font-size: 13px; color: #888; line-height: 1.6">Verified providers near you see your task and apply within minutes.</p>
            </div>
            <div class="card-flat" style="text-align: center; padding: 32px">
                <div style="font-size: 32px; margin-bottom: 14px">✅</div>
                <div style="font-family: 'Playfair Display', serif; font-size: 13px; color: #00A870; margin-bottom: 8px">03</div>
                <h3 style="font-weight: 600; font-size: 16px; margin-bottom: 10px; color: #1a1a2e">Done & paid securely</h3>
                <p style="font-size: 13px; color: #888; line-height: 1.6">Track progress live, complete the job, and pay safely in-app.</p>
            </div>
        </div>
    </div>

    @* Stats Section *@
    <div class="section" style="background: #fff; border-bottom: 1px solid #f0f0f0">
        <div style="display: flex; gap: 0; max-width: 800px; margin: 0 auto; text-align: center">
            <div style="flex: 1; padding: 24px 16px; border-right: 1px solid #f0f0f0">
                <div style="font-family: 'Playfair Display', serif; font-size: 32px; color: #00A870; font-weight: 600">2,400+</div>
                <div style="font-size: 13px; color: #999; margin-top: 6px">Tasks Completed</div>
            </div>
            <div style="flex: 1; padding: 24px 16px; border-right: 1px solid #f0f0f0">
                <div style="font-family: 'Playfair Display', serif; font-size: 32px; color: #00A870; font-weight: 600">830+</div>
                <div style="font-size: 13px; color: #999; margin-top: 6px">Verified Providers</div>
            </div>
            <div style="flex: 1; padding: 24px 16px; border-right: 1px solid #f0f0f0">
                <div style="font-family: 'Playfair Display', serif; font-size: 32px; color: #00A870; font-weight: 600">4.8 ★</div>
                <div style="font-size: 13px; color: #999; margin-top: 6px">Average Rating</div>
            </div>
            <div style="flex: 1; padding: 24px 16px">
                <div style="font-family: 'Playfair Display', serif; font-size: 32px; color: #00A870; font-weight: 600">&lt; 5 min</div>
                <div style="font-size: 13px; color: #999; margin-top: 6px">Avg. Match Time</div>
            </div>
        </div>
    </div>

    @* CTA Section *@
    <div style="background: #1a1a2e; padding: 72px 48px; text-align: center">
        <h2 style="font-family: 'Playfair Display', serif; font-size: 36px; color: #fff; margin-bottom: 12px; letter-spacing: -0.5px">Ready to get started?</h2>
        <p style="color: rgba(255,255,255,0.5); margin-bottom: 36px; font-size: 16px; max-width: 380px; margin: 0 auto 36px">Join thousands of people already using Nexo across Pakistan.</p>
        <div style="display: flex; gap: 16px; justify-content: center">
            <a class="btn btn-ghost" asp-controller="Task" asp-action="Create">Post a Task</a>
            <a class="btn btn-green" href="#">Join as Provider</a>
        </div>
    </div>
</div>
